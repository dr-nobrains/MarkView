<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="selenized-light" _name="Selenized (Light)" version="1.0">
  <author>Generated from Ptyxis</author>
  <_description>Selenized (Light) color scheme</_description>
  <color name="background" value="#fbf3db"/>
  <color name="foreground" value="#53676d"/>
  <color name="cursor" value="#53676d"/>
  <color name="color0" value="#fbf3db"/>
  <color name="color1" value="#d2212d"/>
  <color name="color2" value="#489100"/>
  <color name="color3" value="#ad8900"/>
  <color name="color4" value="#0072d4"/>
