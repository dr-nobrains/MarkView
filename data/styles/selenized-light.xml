  <style name="def:heading" foreground="color4" bold="true"/>
  <style name="def:thematic-break" foreground="color4" bold="true"/>
  <style name="def:preformatted-section" foreground="color12"/>
  
  <style name="def:list-marker" foreground="color5"/>
  <style name="def:error" foreground="foreground" background="color1" bold="true"/>
