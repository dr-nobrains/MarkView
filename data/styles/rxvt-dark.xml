<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="rxvt-dark" _name="RXVT (Dark)" version="1.0">
  <author>Generated from Ptyxis</author>
  <_description>RXVT (Dark) color scheme</_description>
  <color name="foreground" value="#ffffff"/>
  <color name="background" value="#000000"/>
  <color name="cursor" value="#ffffff"/>
  <color name="color0" value="#000000"/>
  <color name="color1" value="#cd0000"/>
  <color name="color2" value="#00cd00"/>
  <color name="color3" value="#cdcd00"/>
  <color name="color4" value="#0000cd"/>
  <color name="color5" value="#cd00cd"/>
  <color name="color6" value="#00cdcd"/>
  <color name="color7" value="#faebd7"/>
  <color name="color8" value="#404040"/>
  <color name="color9" value="#ff0000"/>
  <color name="color10" value="#00ff00"/>
  <color name="color11" value="#ffff00"/>
  <color name="color12" value="#0000ff"/>
  <color name="color13" value="#ff00ff"/>
  <color name="color14" value="#00ffff"/>
  <color name="color15" value="#ffffff"/>

  <!-- Basic styles -->
  <style name="text" foreground="foreground" background="background"/>
  <style name="cursor" foreground="cursor"/>
  <style name="current-line" background="color8"/>
  <style name="line-numbers" foreground="color8" background="background"/>
  <style name="draw-spaces" foreground="color8"/>
  
  <!-- Syntax highlighting -->
  <style name="def:comment" foreground="color8" italic="true"/>
  <style name="def:shebang" foreground="color8" italic="true"/>
  <style name="def:doc-comment-element" bold="true"/>
  
  <style name="def:constant" foreground="color9"/>
  <style name="def:string" foreground="color2"/>
  <style name="def:special-char" foreground="color1"/>
  <style name="def:special-constant" foreground="color1" bold="true"/>
  
  <style name="def:number" foreground="color3"/>
  <style name="def:floating-point" foreground="color3"/>
  <style name="def:boolean" foreground="color3"/>
  
  <style name="def:keyword" foreground="color5" bold="true"/>
  <style name="def:builtin" foreground="color6" bold="true"/>
  <style name="def:variable" foreground="color4"/>
  <style name="def:identifier" foreground="foreground"/>
  <style name="def:function" foreground="color4"/>
  <style name="def:statement" foreground="color5"/>
  <style name="def:type" foreground="color6"/>
  
  <style name="def:emphasis" italic="true"/>
  <style name="def:strong-emphasis" bold="true"/>
  <style name="def:inline-code" foreground="color11" background="color0"/>
  
  <style name="def:insertion" foreground="color2" background="color0"/>
  <style name="def:deletion" foreground="color1" background="color0"/>
  
  <style name="def:link-text" foreground="color4" italic="true" underline="single"/>
  <style name="def:link-symbol" foreground="color4" italic="true"/>
  <style name="def:link-destination" foreground="color6" underline="single"/>
  
  <style name="def:heading" foreground="color4" bold="true"/>
  <style name="def:thematic-break" foreground="color4" bold="true"/>
  <style name="def:preformatted-section" foreground="color12"/>
  
  <style name="def:list-marker" foreground="color5"/>
  <style name="def:error" foreground="foreground" background="color1" bold="true"/>
</style-scheme>
